{
  "name": "zenstack-graphql",
  "version": "0.1.0",
  "description": "A standalone GraphQL adapter for ZenStack V3 with Hasura-like CRUD conventions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "graphql",
    "hasura",
    "zenstack"
  ],
  "license": "MIT",
  "dependencies": {
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
