{
  "name": "zenstack-graphql",
  "version": "0.1.0",
  "description": "A standalone GraphQL adapter for ZenStack V3 with Hasura-like CRUD conventions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/cbsmith402/zenstack-graphql.git"
  },
  "homepage": "https://github.com/cbsmith402/zenstack-graphql#readme",
  "bugs": {
    "url": "https://github.com/cbsmith402/zenstack-graphql/issues"
  },
  "engines": {
    "node": ">=18.17"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./hasura": {
      "types": "./dist/hasura.d.ts",
      "import": "./dist/hasura.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "fetch": [
        "./dist/fetch.d.ts"
      ],
      "hasura": [
        "./dist/hasura.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ci:check": "npm run test && npm run typecheck && npm run build && npm pack --dry-run --cache .npm-cache",
    "hasura:import": "node --import tsx scripts/import-hasura-to-zmodel.ts",
    "demo:express:dev": "npm run dev --prefix examples/express-demo",
    "demo:express:typecheck": "npm run typecheck --prefix examples/express-demo",
    "demo:build": "npm run build --prefix examples/nextjs-demo",
    "demo:dev": "npm run dev --prefix examples/nextjs-demo",
    "demo:hono:dev": "npm run dev --prefix examples/hono-demo",
    "demo:hono:typecheck": "npm run typecheck --prefix examples/hono-demo",
    "demo:tanstack:dev": "npm run dev --prefix examples/tanstack-start-demo",
    "demo:tanstack:typecheck": "npm run typecheck --prefix examples/tanstack-start-demo",
    "demo:typecheck": "npm run typecheck --prefix examples/nextjs-demo",
    "prepublishOnly": "npm run ci:check",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "graphql",
    "hasura",
    "zenstack"
  ],
  "license": "MIT",
  "peerDependencies": {
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.20.0",
    "@zenstackhq/server": "^3.5.1",
    "graphql": "^16.11.0",
    "pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "yaml": "^2.8.3"
  }
}
