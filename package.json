{
  "name": "zenstack-graphql",
  "version": "0.1.0",
  "description": "A standalone GraphQL adapter for ZenStack V3 with Hasura-like CRUD conventions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.17"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "fetch": [
        "./dist/fetch.d.ts"
      ],
      "next": [
        "./dist/next.d.ts"
      ],
      "express": [
        "./dist/express.d.ts"
      ],
      "hono": [
        "./dist/hono.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:build": "npm run build --prefix examples/nextjs-demo",
    "demo:dev": "npm run dev --prefix examples/nextjs-demo",
    "demo:typecheck": "npm run typecheck --prefix examples/nextjs-demo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "graphql",
    "hasura",
    "zenstack"
  ],
  "license": "MIT",
  "peerDependencies": {
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "graphql": "^16.11.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
