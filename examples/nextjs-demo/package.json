{
  "name": "zenstack-graphql-nextjs-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run zen:generate && next build",
    "dev": "npm run zen:generate && next dev",
    "start": "next start",
    "typecheck": "npm run zen:generate && tsc --noEmit",
    "zen:generate": "zenstack generate --no-tips"
  },
  "dependencies": {
    "@zenstackhq/orm": "^3.4.6",
    "better-sqlite3": "^12.8.0",
    "graphql": "^16.11.0",
    "next": "^16.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zenstack-graphql": "file:../.."
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@zenstackhq/cli": "^3.4.6",
    "typescript": "^5.9.2"
  },
  "zenstack": {
    "schema": "./zenstack/schema.zmodel",
    "output": "./zenstack"
  }
